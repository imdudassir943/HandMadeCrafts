# =============================================================================
# HandMadeCrafts Backend - Environment Variable Template
# Copy this file to .env and fill in your values.
# NEVER commit the .env file. Only commit this .env.example.
# =============================================================================

# --- Core Django Settings ---
DEBUG=False
SECRET_KEY=replace-with-your-secure-randomly-generated-secret-key

# Comma-separated list of allowed hosts. Include your Railway deployment domain.
ALLOWED_HOSTS=handmadecrafts-production.up.railway.app,localhost,127.0.0.1

# --- CORS Settings ---
# Your Vercel frontend domain. No trailing slash.
CORS_ALLOWED_ORIGINS=https://hand-made-crafts.vercel.app

# --- CSRF Settings ---
# Required for Django Admin and form POST requests in production.
CSRF_TRUSTED_ORIGINS=https://handmadecrafts-production.up.railway.app

# --- Database ---
# Use Railway's INTERNAL connection URL (private network - faster and more secure).
# Railway injects this automatically when you link the Postgres service.
DATABASE_URL=postgresql://postgres:[PGPASSWORD]@postgres.railway.internal:5432/railway

# --- JWT Authentication ---
# JWT_SECRET_KEY:       Master JWT signing key (fallback if specific keys below are not set).
# ACCESS_TOKEN_SECRET:  Signs short-lived access tokens (configured lifetime: 1 day).
# REFRESH_TOKEN_SECRET: Signs long-lived refresh tokens (configured lifetime: 7 days).
# All three MUST be different from each other and from SECRET_KEY.
# Generate each with: python -c "import secrets; print(secrets.token_urlsafe(50))"
JWT_SECRET_KEY=replace-with-your-secure-randomly-generated-jwt-signing-key
ACCESS_TOKEN_SECRET=replace-with-your-secure-access-token-secret
REFRESH_TOKEN_SECRET=replace-with-your-secure-refresh-token-secret
